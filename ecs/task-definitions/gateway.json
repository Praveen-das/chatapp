{
  "family": "gateway-td",
  "containerDefinitions": [
    {
      "name": "chatapp-gateway-container",
      "image": "483528439286.dkr.ecr.ap-south-1.amazonaws.com/chatapp-gateway:latest",
      "cpu": 256,
      "memory": 512,
      "memoryReservation": 256,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "name": "chatapp-gateway-container-3001-tcp",
          "appProtocol": "http"
        },
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "chatapp-gateway-container-8080-tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/gateway-td",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://127.0.0.1/ping || exit 1"],
        "interval": 160,
        "timeout": 5,
        "retries": 3
      },
      "systemControls": []
    }
  ],
  "taskRoleArn": "arn:aws:iam::483528439286:role/ecsTaskRole",
  "executionRoleArn": "arn:aws:iam::483528439286:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
