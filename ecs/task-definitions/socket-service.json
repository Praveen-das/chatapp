{
  "family": "chatvia-socket-service-td",
  "containerDefinitions": [
    {
      "name": "socket-service-container",
      "image": "483528439286.dkr.ecr.ap-south-1.amazonaws.com/chatvia-socket-service:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3002,
          "hostPort": 3002,
          "protocol": "tcp",
          "name": "socket-service-container-3002-tcp",
          "appProtocol": "http"
        },
        {
          "containerPort": 3003,
          "hostPort": 3003,
          "protocol": "tcp",
          "name": "socket-service-container-3003-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "KAFKA_HOST",
          "value": "kafka-f6c1f2-viralapp.h.aivencloud.com:28909"
        },
        {
          "name": "REDIS_SERVICE_URI",
          "value": "rediss://default:AVNS_D1LlsRwX88JbAGmseag@valkey-2a17d43d-viralapp.a.aivencloud.com:28908"
        },
        {
          "name": "KAFKA_SSL_CERT_B64",
          "value": ""
        },
        {
          "name": "REDIS_HOST",
          "value": "valkey-2a17d43d-viralapp.a.aivencloud.com"
        },
        {
          "name": "SESSION_SERVICE_URL",
          "value": "http://session.api"
        },
        {
          "name": "REDIS_PORT",
          "value": "28908"
        },
        {
          "name": "KAFKA_SSL_KEY_B64",
          "value": ""
        },
        {
          "name": "JWT_ACCESS_TOKEN_SECRET_KEY",
          "value": "8fe4dd1a542ae836b9715e7bc3b8c2f950f886d63c61bbb1fa8cd28f1c020ab78327a7ee69b9d7db325e451e68f959ab779f5e35b1806cc7459749520e39a27f"
        },
        {
          "name": "REDIS_PASSWORD",
          "value": "AVNS_D1LlsRwX88JbAGmseag"
        },
        {
          "name": "KAFKA_SSL_CA_B64",
          "value": ""
        },
        {
          "name": "REDIS_USERNAME",
          "value": "default"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "dockerLabels": {
        "traefik.http.services.chatvia-socket-service.loadbalancer.sticky": "true",
        "traefik.http.routers.socket-service.rule": "PathPrefix(`/socket.io`)",
        "traefik.enable": "true",
        "traefik.http.routers.socket-service": "chatvia-socket-service",
        "traefik.http.routers.socket-service.entrypoints": "web",
        "traefik.http.routers.socket-service.middlewares": "cors-headers@file",
        "traefik.http.services.chatvia-socket-service.loadbalancer.server.port": "3002",
        "traefik.http.services.chatvia-socket-service.loadbalancer.sticky.cookie.name": "sticky_socket",
        "traefik.http.services.chatvia-socket-service.loadbalancer.passHostHeader": "true"
      },
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/chatvia-socket-service-td",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://127.0.0.1:3003/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3
      },
      "systemControls": []
    }
  ],
  "taskRoleArn": "arn:aws:iam::483528439286:role/ecsTaskRole",
  "executionRoleArn": "arn:aws:iam::483528439286:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": ["MANAGED_INSTANCES"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "enableFaultInjection": false
}
