      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "dockerLabels": {
        "traefik.http.routers.session.rule": "PathPrefix(`/session`)",
        "traefik.http.routers.session.service": "chatvia-session-service",
        "traefik.http.routers.session.middlewares": "strip-session,cors-headers@file",
        "traefik.enable": "true",
        "traefik.http.routers.session.entrypoints": "web",
        "traefik.http.services.chatvia-session-service.loadbalancer.server.port": "5000",
        "traefik.http.middlewares.strip-session.stripprefix.prefixes": "/session"
      },
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/chatvia-session-service-td",
