# ── Dependencies ──────────────────────────────────
**/node_modules

# ── Build outputs ─────────────────────────────────
**/.next
**/out
**/build
**/dist
**/coverage
**/.turbo

# ── Environment & secrets ─────────────────────────
**/.env
**/.env.*
**/secrets.dev.yaml
**/secrets.yaml
**/*.pem

# ── Version control & IDE ─────────────────────────
**/.git
**/.gitignore
**/.vscode
**/.idea
**/.DS_Store

# ── Docker (avoid recursive COPY) ────────────────
**/Dockerfile*
**/docker-compose*
**/compose*
**/.dockerignore

# ── Debug logs ────────────────────────────────────
**/npm-debug.log*
**/pnpm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ── Turborepo / package manager cache ─────────────
**/.pnp
**/.pnp.js

# ── Certificates (local dev only) ────────────────
certs/

# ── Docs & meta (not needed in image) ────────────
README.md
BRAND_GUIDELINES.md
LICENSE
.eslintrc.js

# ── Misc ──────────────────────────────────────────
**/dummyData.ts
**/traefik.yml
dynamic/
