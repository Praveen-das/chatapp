{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@features/*": ["features/*"],
      "@lib/*": ["lib/*"],
      "@hooks/*": ["hooks/*"],
      "@interfaces/*": ["interfaces/*"],
      "@helpers/*": ["helpers/*"],
      "@actions/*": ["actions/*"],
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
, "app/(dashboard)/page.tsx", "features/ui/EmojiPicker.tsx", "app/invite/route.js", "app/manifestats", "scripts/generate-vapid-keys.js", "middleware.ts"  ],
  "exclude": ["node_modules"]
}
