{
  "name": "chatapp",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:web": "turbo build --filter=web",
    "dev": "turbo dev",
    "clientOnly": "set NEXT_PUBLIC_CLIENT_ONLY=true && turbo dev --filter=web",
    "web": "turbo dev --filter=web",
    "server": "turbo dev --filter=gateway --filter=backend --filter=socket-service --filter=session-service",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.14.0",
    "prettier": "^3.1.1",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@bull-board/api": "^6.14.2",
    "@bull-board/express": "^6.14.2",
    "@bull-board/ui": "^6.14.2",
    "ai": "^5.0.104",
    "mongoose": "^8.13.2",
    "node-jose-tools": "^2.0.4",
    "zod": "^3.24.2"
  }
}
