:80 {
    # CORS headers for API routes (not socket.io — handled by Socket.IO itself)
    @api_routes {
        not path /socket.io*
    }
    header @api_routes {
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, Cache-Control"
    }

    # Match allowed origins for CORS
    @cors_api_routes {
        not path /socket.io*
        header Origin https://chatapp-web-alpha.vercel.app http://localhost:3000
    }
    header @cors_api_routes {
        Access-Control-Allow-Origin "{header.Origin}"
        Access-Control-Allow-Credentials "true"
        Vary "Origin"
    }

    # Handle preflight OPTIONS requests
    @options {
        method OPTIONS
        not path /socket.io*
    }
    handle @options {
        header {
            Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
            Access-Control-Allow-Headers "Content-Type, Authorization, Cache-Control"
            Access-Control-Max-Age "86400"
        }
        @options_cors header Origin https://chatapp-web-alpha.vercel.app http://localhost:3000
        header @options_cors {
            Access-Control-Allow-Origin "{header.Origin}"
            Access-Control-Allow-Credentials "true"
            Vary "Origin"
        }
        respond 204
    }

    # Route for backend service (database endpoints)
    handle_path /db/* {
        reverse_proxy backend:4000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Route for session service
    handle_path /session/* {
        reverse_proxy sessionservice:5000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Route for socket.io connection / socket-service
    # CORS is handled by Socket.IO's built-in cors option
    handle /socket.io/* {
        reverse_proxy socket-service:3002 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}