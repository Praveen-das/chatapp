# Allow hoisting for packages that expect flat node_modules (Next.js, etc.)
shamefully-hoist=true
# Ensures peer deps are resolved correctly in the monorepo
strict-peer-dependencies=false

# Docker build network resilience (ECONNRESET / TLS flakes)
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=120000
